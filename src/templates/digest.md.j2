{# digest.md.j2 – Jinja2 template for the daily AI digest #}
{# ---- i18n: Chinese / English label maps ---- #}
{% set zh = lang | default("en") == "zh" %}
# 🤖 {{ "AI 日报" if zh else "AI Digest" }} – {{ date }}

> {{ "每日自动汇总来自 Hacker News、GitHub Trends、Hugging Face、ArXiv、Reddit、Product Hunt 和 AI 官方博客的 AI 新闻。" if zh else "Auto-generated daily summary of AI news from Hacker News, GitHub Trends, Hugging Face, ArXiv, Reddit, Product Hunt, and official AI blogs." }}

---

{% if overview %}
## 📋 {{ "今日概览" if zh else "Daily Overview" }}

{{ overview }}

---
{% endif %}

{% if top_story %}
## 🏆 {{ "今日头条" if zh else "Top Story" }}

### [{{ top_story.title }}]({{ top_story.url }})

{{ top_story.summary }}

{% if top_story.score %}⭐ {{ "评分" if zh else "Score" }}: **{{ top_story.score }}**{% endif %} · 📰 {{ "来源" if zh else "Source" }}: **{{ top_story.source }}**{% if top_story.author %} · 👤 {{ top_story.author }}{% endif %}{% if top_story.category %} · 🏷️ {{ top_story.category }}{% endif %}

---
{% endif %}

{% set hn_articles = articles | selectattr("source", "equalto", "hackernews") | list %}
{% set gh_articles = articles | selectattr("source", "equalto", "github") | list %}
{% set hf_articles = articles | selectattr("source", "equalto", "huggingface") | list %}
{% set arxiv_articles = articles | selectattr("source", "equalto", "arxiv") | list %}
{% set reddit_articles = articles | selectattr("source", "equalto", "reddit") | list %}
{% set ph_articles = articles | selectattr("source", "equalto", "producthunt") | list %}
{% set blog_articles = articles | selectattr("source", "equalto", "ai_blogs") | list %}

{% if blog_articles %}
## 🏢 {{ "AI 官方博客" if zh else "Official AI Blogs" }}

| # | {{ "标题" if zh else "Title" }} | {{ "公司" if zh else "Company" }} | {{ "摘要" if zh else "Summary" }} |
|---|-------|---------|---------|
{% for a in blog_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title | truncate(80) }}]({{ a.url }}) | {{ a.author or "–" }} | {{ a.summary or a.description | truncate(150) }} |
{% endif %}
{% endfor %}

{% endif %}
{% if hn_articles %}
## 📰 Hacker News {{ "热门" if zh else "" }}

| # | {{ "标题" if zh else "Title" }} | {{ "评分" if zh else "Score" }} | 💬 | {{ "分类" if zh else "Category" }} | {{ "摘要" if zh else "Summary" }} |
|---|-------|------:|---:|----------|---------|
{% for a in hn_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title }}]({{ a.url }}) | {{ a.score or "–" }} | {{ a.comment_count or "–" }} | {{ a.category or "–" }} | {{ a.summary }} |
{% endif %}
{% endfor %}

{% endif %}
{% if reddit_articles %}
## 💬 Reddit {{ "热门" if zh else "" }}

| # | {{ "标题" if zh else "Title" }} | {{ "版块" if zh else "Subreddit" }} | {{ "评分" if zh else "Score" }} | 💬 | {{ "摘要" if zh else "Summary" }} |
|---|-------|-----------|------:|---:|---------|
{% for a in reddit_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title | truncate(80) }}]({{ a.url }}) | {{ a.tags[0] if a.tags else "–" }} | {{ a.score or "–" }} | {{ a.comment_count or "–" }} | {{ a.summary or a.description | truncate(150) }} |
{% endif %}
{% endfor %}

{% endif %}
{% if gh_articles %}
## 🔥 GitHub {{ "趋势" if zh else "Trending" }}

| # | {{ "仓库" if zh else "Repository" }} | ⭐ {{ "星标" if zh else "Stars" }} | 📈 {{ "今日" if zh else "Today" }} | {{ "语言" if zh else "Language" }} | {{ "描述" if zh else "Description" }} |
|---|-----------|--------:|--------:|----------|-------------|
{% for a in gh_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title }}]({{ a.url }}) | {{ "{:,}".format(a.score) if a.score else "–" }} | {{ "+{}".format(a.stars_today) if a.stars_today else "–" }} | {{ a.language or "–" }} | {{ a.summary or a.description }} |
{% endif %}
{% endfor %}

{% endif %}
{% if arxiv_articles %}
## 📄 ArXiv {{ "论文" if zh else "Papers" }}

| # | {{ "标题" if zh else "Title" }} | {{ "作者" if zh else "Authors" }} | {{ "分类" if zh else "Category" }} | {{ "摘要" if zh else "Summary" }} |
|---|-------|---------|----------|---------|
{% for a in arxiv_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title | truncate(80) }}]({{ a.url }}) | {{ a.author or "–" }} | {{ a.category or "–" }} | {{ a.summary or a.description | truncate(150) }} |
{% endif %}
{% endfor %}

{% endif %}
{% if hf_articles %}
## 🤗 Hugging Face {{ "热门" if zh else "" }}

| # | {{ "标题" if zh else "Title" }} | {{ "类型" if zh else "Type" }} | {{ "分类" if zh else "Category" }} | {{ "摘要" if zh else "Summary" }} |
|---|-------|------|----------|---------|
{% for a in hf_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title | truncate(80) }}]({{ a.url }}) | {{ a.tags[0] if a.tags else "–" }} | {{ a.category or "–" }} | {{ a.summary or a.description | truncate(200) }} |
{% endif %}
{% endfor %}

{% endif %}
{% if ph_articles %}
## 🚀 Product Hunt {{ "新品" if zh else "" }}

| # | {{ "产品" if zh else "Product" }} | {{ "票数" if zh else "Votes" }} | {{ "摘要" if zh else "Summary" }} |
|---|---------|------:|---------|
{% for a in ph_articles %}
{% if not top_story or a.url != top_story.url %}
| {{ loop.index }} | [{{ a.title }}]({{ a.url }}) | {{ a.score or "–" }} | {{ a.summary or a.description | truncate(150) }} |
{% endif %}
{% endfor %}

{% endif %}

---

## 📊 {{ "统计" if zh else "Statistics" }}

| {{ "来源" if zh else "Source" }} | {{ "数量" if zh else "Count" }} |
|--------|------:|
| {{ "AI 官方博客" if zh else "Official AI Blogs" }} | {{ blog_articles | length }} |
| Hacker News | {{ hn_articles | length }} |
| Reddit | {{ reddit_articles | length }} |
| GitHub Trending | {{ gh_articles | length }} |
| ArXiv | {{ arxiv_articles | length }} |
| Hugging Face | {{ hf_articles | length }} |
| Product Hunt | {{ ph_articles | length }} |
| **{{ "合计" if zh else "Total" }}** | **{{ articles | length }}** |

{% set categories = articles | map(attribute='category') | select | unique | list %}
{% if categories %}
**{{ "主题分布" if zh else "Topic Distribution" }}**: {{ categories | join(" · ") }}
{% endif %}

