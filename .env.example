# =============================================================================
# AIDigest – Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- LLM Provider ----------------------------------------------------------
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Scraping ---------------------------------------------------------------
# Maximum number of items to fetch per source
HN_MAX_STORIES=30
GITHUB_MAX_REPOS=20
HF_MAX_ITEMS=20
ARXIV_MAX_PAPERS=15
REDDIT_MAX_POSTS=15
PH_MAX_PRODUCTS=10
BLOG_MAX_POSTS=10
BLOG_DAYS_LOOKBACK=2

# --- Output -----------------------------------------------------------------
ARCHIVES_DIR=archives

# Summary language: "zh" for Chinese, "en" for English
SUMMARY_LANGUAGE=zh
